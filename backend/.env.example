# ── OpenRouter (required for the 5-agent pipeline) ────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
# Optional: override base URL (default: https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Gemini (optional, still used for /api/chat helper) ────────────────────
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://lumos_app:<password>@127.0.0.1:5432/lumos_db

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret
